extends layout

block content
	section.hero
		.hero-content
			img(src='/images/logo_dark.png' alt='Downtown Donuts logo' class='hero-logo')
			a(href='/menu' class='btn btn-primary') View Our Menu
	section.best-sellers
		h2 Our Best Sellers
		.grid-cards
			article.card
				img(src='/images/glazed.png' alt='Classic glazed donut')
				h3 Creamed Core
				p Glazed all around the hole
			article.card
				img(src='/images/chocolate.jpg' alt='Chocolate Old Fashioned donut')
				h3 Big Brown Eye
				p Doo doo doo, looking out your backdoor
			article.card
				img(src='/images/maple_bacon.jpg' alt='Maple Bacon Bar')
				h3 Canada Stick
				p Thick maple log
	section.visit
		h2 Visit Us
		.visit-content
			.visit-info
				p 123 Main Street, Downtown
				p Open Daily 6AM — 2PM
				p (555) 867-5309
			.visit-map
				img(src='/images/map.png' alt='Map of 123 Main Street, Downtown')
	section.order
		h2 Order Online
		p Get Donuts delivered to your door.
		.order-links
			a(href='https://www.ubereats.com' class='btn btn-outline') Uber Eats
			a(href='https://www.doordash.com' class='btn btn-outline') DoorDash
			a(href='https://www.grubhub.com' class='btn btn-outline') GrubHub